in!\nAnime Recommendations · Smash or pass + more!'}, {'type': 14, 'spacing': 1, 'id': 15, 'divider': True}, {'type': 10, 'id': 16, 'content': '📖 **Need help?**'}, {'type': 10, 'id': 17, 'content': 'Use `/help` or `m.help` for the **full interactive command guide** with page navigation, or join our Support server below! 😼'}, {'type': 14, 'spacing': 1, 'id': 18, 'divider': True}, {'type': 1, 'id': 19, 'components': [{'type': 2, 'style': 1, 'label': 'Start a Call', 'id': 20, 'emoji': {'name': '📞'}, 'disabled': True, 'custom_id': 'a2a2b68fa88649b44a0af2734ddfac1f'}, {'url': 'https://top.gg/bot/1355389597818945639/vote', 'type': 2, 'style': 5, 'label': 'Vote on Top.gg', 'id': 21, 'emoji': {'name': '⭐'}}, {'url': 'https://discord.gg/7vxJbzKY5E', 'type': 2, 'style': 5, 'label': 'Support Server', 'id': 22, 'emoji': {'name': '😺'}}, {'url': 'https://meowcall.xyz', 'type': 2, 'style': 5, 'label': 'Website', 'id': 23, 'emoji': {'name': '🌐'}}]}, {'type': 14, 'spacing': 1, 'id': 24, 'divider': True}, {'type': 10, 'id': 25, 'content': '-# MeowCall • Connecting the Meowverse 🐾 | Now in 3305 servers'}], 'accent_color': 16731060}], 'channel_type': 0, 'channel_id': '1500788592048607306', 'author': {'username': 'Meowcall', 'public_flags': 65536, 'primary_guild': None, 'id': '1355389597818945639', 'global_name': None, 'display_name_styles': None, 'discriminator': '4699', 'collectibles': None, 'clan': None, 'bot': True, 'avatar_decoration_data': None, 'avatar': 'ccf2779f20fafee01e95fb9a79bbd410'}, 'attachments': [], 'guild_id': '1500788591222198314'}}
